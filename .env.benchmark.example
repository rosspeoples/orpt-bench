# Copy to .env.benchmark for local benchmark settings.
# Put provider credentials in `.env` or your shell environment.
# Example for OpenCode Zen / OpenCode Go:
# OPENCODE_API_KEY=...

# Example local dev settings after applying a generated matrix.
# Recommended: `docker compose run --rm runner use-matrix dev`
BENCHMARK_MODELS=opencode/gpt-5.4-mini
BENCHMARK_REPEATS=1
BENCHMARK_PROVIDER=opencode
BENCHMARK_AGENT=build
BENCHMARK_TASK_GLOB=*
BENCHMARK_TIMEOUT_SECONDS=600
BENCHMARK_PROCESS_TIMEOUT_SECONDS=0
BENCHMARK_WRITE_README=1
