  },
  "lifecycle": {
    "sunsetAfterDays": 30,
    "promotionSmokeSuccessesRequired": 2,
    "bootstrapSmokePromotionBefore": "2026-04-07T16:12:30.832Z",
    "forceActiveModels": [],
    "forceDeprecatedModels": [],
    "forceSunsetModels": []
