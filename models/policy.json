    "weekly": {
      "description": "Primary comparable weekly benchmark run",
      "matrix": "current_task_cheap_comparable",
      "fallbackMatrices": [
        "cheap_headless",
        "cheap",
        "dev"
      ],
      "taskGlob": "*",
      "repeats": 1
    },
    "monthly": {
      "description": "Higher-signal monthly benchmark run over the release cohort",
      "matrix": "release",
      "fallbackMatrices": [
        "frontier",
        "balanced"
      ],
      "taskGlob": "*",
      "repeats": 1
    }
  }
