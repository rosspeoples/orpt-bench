# Example release/leaderboard settings after applying a generated matrix.
# Recommended: `docker compose run --rm runner use-matrix release`
# Keep credentials in `.env` or your shell environment.

BENCHMARK_MODELS=opencode/gemini-3.1-pro,opencode/gpt-5.4,opencode/claude-sonnet-4-6,opencode/glm-5,opencode/claude-opus-4-6
BENCHMARK_REPEATS=1
BENCHMARK_PROVIDER=opencode
BENCHMARK_AGENT=build
BENCHMARK_TASK_GLOB=*
BENCHMARK_TIMEOUT_SECONDS=600
BENCHMARK_PROCESS_TIMEOUT_SECONDS=0
BENCHMARK_WRITE_README=1
